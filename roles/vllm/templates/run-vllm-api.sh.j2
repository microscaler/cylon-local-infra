#!/bin/bash
# Wrapper so vLLM finds libcudart (e.g. .so.12 or .so.13) when run from systemd (minimal env).
set -e
export PYTHONUNBUFFERED=1
export HF_HOME="${HF_HOME:-{{ vllm_hf_home }}}"
export VLLM_ENGINE_READY_TIMEOUT_S="{{ vllm_engine_ready_timeout_sec | default(1800) }}"
{% for _k, _v in (vllm_distributed_extra_env | default({}) | dictsort) %}
export {{ _k }}={{ _v | string | quote }}
{% endfor %}

# CUDA runtime: load vendor env if present, then ensure these paths are first.
# Order: PyTorch libs (libtorch, c10) — then libcudart (.12 from cuda-cudart-12-* or .13 from toolkit) — then system.
[ -f /usr/local/cuda/bin/cuda_env.sh ] && . /usr/local/cuda/bin/cuda_env.sh
export LD_LIBRARY_PATH="{{ vllm_torch_lib_path | default('') }}{% if vllm_torch_lib_path | default('') | length > 0 %}:{% endif %}{{ vllm_cuda_lib_path }}:/usr/local/cuda/lib64:/usr/local/cuda/lib:/usr/lib/aarch64-linux-gnu:/usr/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH:-}"

{% set _vllm_ex = vllm_api_server_extra_args | default([]) %}
{% set _vllm_ez = vllm_enforce_eager | default(false) %}
exec "{{ vllm_venv_path }}/bin/python" -m vllm.entrypoints.openai.api_server \
  --host "{{ vllm_api_host }}" \
  --model "{{ vllm_default_model }}" \
  --port {{ vllm_api_port }}{% if vllm_load_format | default('') | length > 0 %} --load-format {{ vllm_load_format }}{% endif %}{% if _vllm_ex | length > 0 %} {{ _vllm_ex | join(' ') }}{% endif %}{% if _vllm_ez %} --enforce-eager{% endif %}
