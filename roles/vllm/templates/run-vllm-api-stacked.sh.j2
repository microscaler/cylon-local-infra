#!/bin/bash
# vLLM OpenAI API — tensor-parallel across Sparks via Ray (stacked). LD_LIBRARY_PATH matches single-node wrapper.
set -e
export PYTHONUNBUFFERED=1
export HF_HOME="${HF_HOME:-{{ vllm_hf_home }}}"
[ -f /usr/local/cuda/bin/cuda_env.sh ] && . /usr/local/cuda/bin/cuda_env.sh
export LD_LIBRARY_PATH="{{ vllm_torch_lib_path | default('') }}{% if vllm_torch_lib_path | default('') | length > 0 %}:{% endif %}{{ vllm_cuda_lib_path }}:/usr/local/cuda/lib64:/usr/local/cuda/lib:/usr/lib/aarch64-linux-gnu:/usr/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH:-}"
export VLLM_HOST_IP="{{ spark_interconnect_ip }}"
export VLLM_ENGINE_READY_TIMEOUT_S="{{ vllm_engine_ready_timeout_sec | default(1800) }}"
{% for _k, _v in (vllm_distributed_extra_env | default({}) | dictsort) %}
export {{ _k }}={{ _v | string | quote }}
{% endfor %}
# Delay before vLLM (Ray worker join / GCS settle). Must live in this script — not systemd ExecStartPre —
# long sleeps there are sometimes SIGTERM'd as the "control process" before ExecStart runs.
sleep {{ vllm_stack_vllm_start_delay_sec | default(25) }}
{% set _vllm_ex = vllm_api_server_extra_args | default([]) %}
{% set _vllm_ez = vllm_enforce_eager | default(false) %}
exec "{{ vllm_venv_path }}/bin/python" -m vllm.entrypoints.openai.api_server \
  --host "{{ vllm_api_host }}" \
  --model "{{ vllm_default_model }}" \
  --port {{ vllm_api_port }}{% if vllm_load_format | default('') | length > 0 %} \
  --load-format {{ vllm_load_format }}{% endif %} \
  --tensor-parallel-size {{ vllm_tensor_parallel_size | default(2) }} \
  --distributed-executor-backend ray{% if _vllm_ex | length > 0 %} \
  {{ _vllm_ex | join(' ') }}{% endif %}{% if _vllm_ez %} \
  --enforce-eager{% endif %}
