{# Per-host env for torchrun + external_launcher. NCCL vars are local — no Ray carry-over. #}
VLLM_HOST_IP={{ spark_interconnect_ip }}
MASTER_ADDR={{ spark_torchrun_leader_ip }}
MASTER_PORT={{ vllm_torchrun_stacked_rdzv_port | int }}
{# Host cache is bind-mounted at /root/.cache/huggingface — do not use host paths here. #}
HF_HOME={{ vllm_torchrun_stacked_hf_container_home }}
HUGGINGFACE_HUB_CACHE={{ vllm_torchrun_stacked_hf_container_home }}/hub
TRANSFORMERS_OFFLINE=1
{% if vllm_torchrun_stacked_v1_multiprocessing_disabled | bool %}
VLLM_ENABLE_V1_MULTIPROCESSING=0
{% endif %}
{% for _k, _v in (vllm_distributed_extra_env | default({}) | dictsort) %}
{{ _k }}={{ _v }}
{% endfor %}
{% for _k, _v in (vllm_torchrun_stacked_extra_env | default({}) | dictsort) %}
{{ _k }}={{ _v }}
{% endfor %}
NCCL_IB_GID_INDEX={{ spark_nccl_ib_gid_index | default('3') }}
