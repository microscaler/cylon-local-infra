{# Worker: VLLM_HOST_IP is this host; MASTER_ADDR / head address for Ray join — NVIDIA Step 5. #}
VLLM_HOST_IP={{ spark_interconnect_ip }}
MASTER_ADDR={{ spark_ray_head_ip }}
{% for _k, _v in (vllm_distributed_extra_env | default({}) | dictsort) %}
{{ _k }}={{ _v }}
{% endfor %}
{# Per-host: RoCE v2+IPv4 GID index differs across GX10 units (show_gids). Must be last so it wins. #}
NCCL_IB_GID_INDEX={{ spark_nccl_ib_gid_index | default('3') }}
