#!/bin/bash
# Ansible-managed wrapper: spark-vllm-docker launch-cluster.sh exec …
set -euo pipefail
cd "{{ vllm_docker_install_path }}"
export CONFIG_FILE="{{ vllm_docker_config_dir }}/cluster.env"
exec ./launch-cluster.sh \
  --config "$CONFIG_FILE" \
  -t "{{ vllm_docker_image }}" \
  --name "{{ vllm_docker_container_name }}" \
  --master-port "{{ vllm_docker_master_port }}" \
  exec vllm serve \
  "{{ vllm_docker_model }}" \
  --port {{ vllm_docker_api_port }} \
  --host {{ vllm_docker_api_host }} \
  --gpu-memory-utilization {{ vllm_docker_gpu_memory_utilization }} \
  -tp {{ vllm_docker_tensor_parallel }} \
  --distributed-executor-backend ray \
  --max-model-len {{ vllm_docker_max_model_len }} \
  --load-format {{ vllm_docker_load_format }}{% if vllm_docker_extra_serve_args | default([]) | length > 0 %} \
  {{ vllm_docker_extra_serve_args | join(' ') }}{% endif %}
